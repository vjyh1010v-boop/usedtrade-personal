<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pknu26.usedtrade.mapper.UserMapper">

    <!-- 회원가입 -->
    <insert id="insertUser">
        INSERT INTO users (
            user_id,
            login_id,
            user_name,
            password,
            nickname,
            role,
            phone
        ) VALUES (
            seq_user_id.NEXTVAL,
            #{loginId},
            #{userName},
            #{password},
            #{nickname},
            #{role},
            #{phone}
        )
    </insert>

    <!-- 아이디 중복 체크 -->
    <select id="findByLoginId" resultType="UserDTO">
        SELECT *
        FROM users
        WHERE login_id = #{loginId}
    </select>

</mapper>